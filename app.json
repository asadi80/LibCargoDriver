{
  "expo": {
    "name": "LibCargo Driver",
    "slug": "LibCargo Driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontenddriver",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "react-native-maps",
        {
          "androidGoogleMapsApiKey": "AIzaSyAkJCazEKocBcXX-XfDNiv9NF3MySlyCrU",
          "iosGoogleMapsApiKey": "AIzaSyAkJCazEKocBcXX-XfDNiv9NF3MySlyCrU"
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#00020d",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          },
          "ios": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 200,
            "imageHeight": 200
          }
        }
      ],
      "expo-secure-store",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
